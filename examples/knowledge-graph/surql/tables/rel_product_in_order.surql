DEFINE TABLE OVERWRITE REL_PRODUCT_IN_ORDER SCHEMAFULL
    TYPE RELATION IN product OUT order
    PERMISSIONS
        FOR select FULL,
        FOR create, update, delete NONE;

DEFINE FIELD OVERWRITE qty ON TABLE REL_PRODUCT_IN_ORDER TYPE number;

DEFINE INDEX IF NOT EXISTS rel_product_in_order_unique_idx ON REL_PRODUCT_IN_ORDER FIELDS in, out UNIQUE;
